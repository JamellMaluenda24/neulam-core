<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 24px 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid transparent;
    transition: all 0.3s ease;
  }
  nav.scrolled {
    background: rgba(5,8,16,0.9);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }
  .nav-logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 20px;
    letter-spacing: -0.5px;
    color: var(--text);
    text-decoration: none;
    position: relative;
    z-index: 110;
  }
  .nav-logo span { color: var(--accent); }

  .nav-links {
    display: flex;
    gap: 40px;
    list-style: none;
  }
  .nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-cta {
    background: var(--accent) !important;
    color: var(--bg) !important;
    padding: 10px 22px;
    border-radius: 100px;
    font-weight: 500 !important;
    font-size: 13px !important;
    transition: all 0.2s !important;
  }
  .nav-cta:hover { background: #fff !important; }

  /* Hamburger button */
  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    position: relative;
    z-index: 110;
  }
  .nav-burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
    transform-origin: center;
  }
  .nav-burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-burger.open span:nth-child(2) { opacity: 0; width: 0; }
  .nav-burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile drawer */
  .nav-drawer {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 105;
    pointer-events: none;
  }
  .nav-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .nav-panel {
    position: absolute;
    top: 0; right: 0;
    width: min(320px, 85vw);
    height: 100%;
    background: #0f0f1a;
    border-left: 1px solid var(--border);
    padding: 100px 32px 40px;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .nav-drawer.open {
    pointer-events: all;
  }
  .nav-drawer.open .nav-backdrop { opacity: 1; }
  .nav-drawer.open .nav-panel { transform: translateX(0); }

  .nav-drawer ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .nav-drawer ul li a {
    display: block;
    color: var(--muted);
    text-decoration: none;
    font-size: 17px;
    font-weight: 400;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.2s, padding-left 0.2s;
  }
  .nav-drawer ul li:last-child a { border-bottom: none; }
  .nav-drawer ul li a:hover { color: var(--text); padding-left: 6px; }
  .nav-drawer .drawer-cta {
    margin-top: 32px;
    background: var(--accent);
    color: var(--bg);
    padding: 14px 24px;
    border-radius: 12px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    text-align: center;
    transition: background 0.2s;
  }
  .nav-drawer .drawer-cta:hover { background: #fff; }

  @media (max-width: 900px) {
    nav { padding: 16px 20px; }
    .nav-links { display: none; }
    .nav-burger { display: flex; }
    .nav-drawer { display: block; }
  }

  @media (max-width: 375px) {
    nav { padding: 14px 16px; }
    .nav-logo { font-size: 18px; }
    .nav-panel { padding: 90px 24px 32px; }
  }
</style>

<nav id="navbar">
  <a href="/" class="nav-logo">Neulam<span>Core</span></a>
  <ul class="nav-links">
    <li><a href="/#about">Nosotros</a></li>
    <li><a href="/#app">Ascend</a></li>
    <li><a href="/privacy">Privacidad</a></li>
    <li><a href="/#contact">Contacto</a></li>
    <li><a href="https://portafolio-jamell-maluenda.vercel.app/" target="_blank" class="nav-cta">Portafolio →</a></li>
  </ul>
  <button class="nav-burger" id="navBurger" aria-label="Abrir menú">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="nav-drawer" id="navDrawer">
  <div class="nav-backdrop" id="navBackdrop"></div>
  <div class="nav-panel">
    <ul>
      <li><a href="/#about" class="drawer-link">Nosotros</a></li>
      <li><a href="/#app" class="drawer-link">Ascend</a></li>
      <li><a href="/privacy" class="drawer-link">Privacidad</a></li>
      <li><a href="/#contact" class="drawer-link">Contacto</a></li>
    </ul>
    <a href="https://portafolio-jamell-maluenda.vercel.app/" target="_blank" class="drawer-cta">Ver Portafolio →</a>
  </div>
</div>

<script>
  const burger = document.getElementById('navBurger');
  const drawer = document.getElementById('navDrawer');
  const backdrop = document.getElementById('navBackdrop');

  function toggleMenu(open) {
    burger.classList.toggle('open', open);
    drawer.classList.toggle('open', open);
    document.body.style.overflow = open ? 'hidden' : '';
  }

  burger.addEventListener('click', () => toggleMenu(!drawer.classList.contains('open')));
  backdrop.addEventListener('click', () => toggleMenu(false));
  document.querySelectorAll('.drawer-link').forEach(link => {
    link.addEventListener('click', () => toggleMenu(false));
  });

  window.addEventListener('scroll', () => {
    document.getElementById('navbar')?.classList.toggle('scrolled', window.scrollY > 40);
  });
</script>
