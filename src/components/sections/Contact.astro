<style>
  .contact-wrap {
    padding: 140px 60px;
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .contact-info h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 800;
    letter-spacing: -1.5px;
    margin-bottom: 20px;
    line-height: 1.1;
  }
  .contact-info p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    font-weight: 300;
    margin-bottom: 36px;
  }
  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--accent);
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    padding: 14px 24px;
    border: 1px solid rgba(79,255,176,0.2);
    border-radius: 12px;
    background: rgba(79,255,176,0.05);
    transition: all 0.3s;
  }
  .contact-link:hover {
    background: rgba(79,255,176,0.1);
    border-color: rgba(79,255,176,0.4);
    transform: translateY(-2px);
  }
  .social-links {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 32px;
  }
  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--muted);
    text-decoration: none;
    font-size: 13px;
    padding: 8px 16px;
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: all 0.2s;
  }
  .social-link:hover { border-color: rgba(79,255,176,0.3); color: var(--accent); }

  .contact-form {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 40px;
    position: relative;
    overflow: hidden;
  }
  .contact-form::before {
    content: '';
    position: absolute;
    top: -1px; left: -1px; right: -1px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--accent2), transparent);
  }
  .form-group { margin-bottom: 20px; }
  .form-group label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .form-group input,
  .form-group textarea {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 16px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    resize: none;
  }
  .form-group input:focus,
  .form-group textarea:focus {
    border-color: rgba(79,255,176,0.4);
    box-shadow: 0 0 0 3px rgba(79,255,176,0.06);
  }
  .form-group textarea { height: 120px; }
  .form-submit {
    width: 100%;
    background: var(--accent);
    color: var(--bg);
    border: none;
    padding: 15px;
    border-radius: 12px;
    font-family: 'Syne', sans-serif;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s;
    letter-spacing: 0.02em;
    margin-top: 8px;
  }
  .form-submit:hover {
    background: #fff;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(79,255,176,0.25);
  }
  .form-msg {
    text-align: center;
    padding: 12px;
    border-radius: 10px;
    font-size: 14px;
    margin-top: 12px;
    display: none;
  }
  .form-msg.success {
    background: rgba(79,255,176,0.1);
    border: 1px solid rgba(79,255,176,0.3);
    color: var(--accent);
    display: block;
  }
  .form-msg.error {
    background: rgba(255,107,107,0.1);
    border: 1px solid rgba(255,107,107,0.3);
    color: var(--accent3);
    display: block;
  }
  @media (max-width: 900px) {
    .contact-wrap { grid-template-columns: 1fr; gap: 40px; padding: 80px 24px; }
    .contact-info h2 { letter-spacing: -1px; }
  }

  @media (max-width: 480px) {
    .contact-wrap { padding: 60px 20px; gap: 32px; }
    .contact-form { padding: 24px 20px; border-radius: 18px; }
    .contact-info p { font-size: 15px; margin-bottom: 24px; }
    .contact-link { font-size: 14px; padding: 12px 18px; }
    .form-group input,
    .form-group textarea { padding: 12px 14px; font-size: 15px; }
  }
</style>

<section id="contact" style="position:relative;z-index:1;">
  <div class="contact-wrap">
    <div class="contact-info">
      <div style="font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);margin-bottom:20px;font-weight:500;">// Contacto</div>
      <h2>Hablemos.<br>En serio.</h2>
      <p>¿Ideas, colaboraciones, feedback sobre Ascend o simplemente quieres conectar? Estamos disponibles.</p>
      <a href="https://portafolio-jamell-maluenda.vercel.app/" target="_blank" class="contact-link">
        <span>⬡</span> Ver Portafolio de Jamell Maluenda
      </a>
      <div style="margin-top: 12px; font-size: 12px; color: var(--muted); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 32px;">También en</div>
      <div class="social-links">
        <a href="https://portafolio-jamell-maluenda.vercel.app/" target="_blank" class="social-link">Portfolio →</a>
        <a href="https://github.com/JamellMaluenda24" target="_blank" class="social-link">GitHub →</a>
      </div>
    </div>

    <div class="contact-form">
      <h3 style="font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 700; margin-bottom: 24px;">Envíanos un mensaje</h3>
      <form id="contactForm">
        <div class="form-group">
          <label>Nombre</label>
          <input type="text" id="fname" placeholder="Tu nombre" required />
        </div>
        <div class="form-group">
          <label>Email</label>
          <input type="email" id="femail" placeholder="tu@email.com" required />
        </div>
        <div class="form-group">
          <label>Asunto</label>
          <input type="text" id="fsubject" placeholder="¿De qué quieres hablar?" />
        </div>
        <div class="form-group">
          <label>Mensaje</label>
          <textarea id="fmessage" placeholder="Cuéntanos..." required></textarea>
        </div>
        <button type="submit" class="form-submit">Enviar mensaje →</button>
      </form>
      <div id="formMsg" class="form-msg"></div>
    </div>
  </div>
</section>

<script>
  gsap.from('.contact-info', {
    scrollTrigger: { trigger: '.contact-wrap', start: 'top 70%' },
    opacity: 0, x: -30, duration: 0.7, ease: 'power2.out'
  });
  gsap.from('.contact-form', {
    scrollTrigger: { trigger: '.contact-wrap', start: 'top 70%' },
    opacity: 0, x: 30, duration: 0.7, ease: 'power2.out'
  });

  document.getElementById('contactForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const msg = document.getElementById('formMsg');
    const btn = document.querySelector('.form-submit');
    btn.textContent = 'Enviando...';
    btn.disabled = true;

    const formData = {
      access_key: '3912b8ee-eee0-4155-9dc9-7abc0ddcaf39',
      name: document.getElementById('fname').value,
      email: document.getElementById('femail').value,
      subject: document.getElementById('fsubject').value || 'Mensaje desde Neulam Core',
      message: document.getElementById('fmessage').value,
    };

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(formData),
      });
      const data = await res.json();
      if (data.success) {
        msg.className = 'form-msg success';
        msg.textContent = '✓ Mensaje enviado. Te responderemos pronto.';
        document.getElementById('contactForm').reset();
        setTimeout(() => { msg.className = 'form-msg'; msg.textContent = ''; }, 5000);
      } else {
        throw new Error(data.message || 'Error al enviar');
      }
    } catch (err) {
      msg.className = 'form-msg error';
      msg.textContent = '✗ Hubo un error al enviar. Inténtalo de nuevo.';
    } finally {
      btn.textContent = 'Enviar mensaje →';
      btn.disabled = false;
    }
  });
</script>
