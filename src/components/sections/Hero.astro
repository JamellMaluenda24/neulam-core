<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 40px 80px;
    position: relative;
  }
  .hero-inner { max-width: 900px; }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(0,212,200,0.08);
    border: 1px solid rgba(0,212,200,0.2);
    color: var(--accent);
    padding: 7px 16px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 40px;
    opacity: 0;
  }
  .hero-badge::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse-dot 2s infinite;
  }
  .hero h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(52px, 8vw, 100px);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -3px;
    margin-bottom: 32px;
    opacity: 0;
  }
  .hero h1 em {
    font-style: normal;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255,255,255,0.3);
  }
  .hero h1 .accent-word { color: var(--accent); }
  .hero-sub {
    font-size: 18px;
    color: var(--muted);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto 48px;
    font-weight: 300;
    opacity: 0;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: center;
    opacity: 0;
    flex-wrap: wrap;
    width: 100%;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
  }
  .freemium-note {
    width: 100%;
    text-align: center;
    font-size: 12px;
    color: var(--muted);
    margin-top: 4px;
    letter-spacing: 0.03em;
  }
  .freemium-note span { color: var(--accent); font-weight: 500; }
  .orb1 {
    position: absolute;
    top: 30%; left: 10%;
    width: 400px; height: 400px;
    background: rgba(0,212,200,0.05);
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
  }
  .orb2 {
    position: absolute;
    top: 20%; right: 5%;
    width: 300px; height: 300px;
    background: rgba(0,181,170,0.06);
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .hero { padding: 100px 24px 60px; }
    .hero h1 { letter-spacing: -2px; margin-bottom: 24px; }
    .hero-sub { font-size: 16px; margin-bottom: 36px; }
    .hero-actions { gap: 12px; max-width: 340px; }
    .orb1 { width: 250px; height: 250px; top: 20%; left: -5%; }
    .orb2 { width: 200px; height: 200px; top: 10%; right: -5%; }
    .freemium-note { font-size: 11px; }
  }

  @media (max-width: 480px) {
    .hero { padding: 90px 20px 60px; }
    .hero-inner { width: 100%; }
    .hero h1 { letter-spacing: -1.5px; }
    .hero-sub { font-size: 15px; margin-bottom: 28px; }
    .hero-actions { max-width: 100%; gap: 10px; }
    .hero-scroll { display: none; }
    .hero-badge { font-size: 11px; padding: 6px 12px; margin-bottom: 28px; }
  }

  @media (max-width: 375px) {
    .hero { padding: 80px 16px 50px; }
    .hero h1 { font-size: 44px; letter-spacing: -1px; }
    .hero-sub { font-size: 14px; }
  }
</style>

<section class="hero">
  <div class="orb1"></div>
  <div class="orb2"></div>
  <div class="hero-inner">
    <div class="hero-badge">Neulam Core — Auctus v1.0</div>
    <h1>
      Construye hábitos.<br>
      <span class="accent-word">Crece</span><br>
      <em>sin límites.</em>
    </h1>
    <p class="hero-sub">Auctus —del latín <span style="font-style:italic;color:var(--text);">crecimiento</span>— es un rastreador de hábitos para quienes toman en serio su progreso. Sube de rango, protege tus rachas y mide tu disciplina. <span style="color:var(--text);font-weight:400;">Gratis para empezar.</span></p>
    <div class="hero-actions">
      <a href="#app" class="btn-primary">Explorar Auctus ↓</a>
      <p class="freemium-note"><span>Gratis</span> para siempre · Desbloquea más con <span>Premium</span></p>
    </div>
  </div>
  <div class="hero-scroll">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<script>
  gsap.registerPlugin(ScrollTrigger);
  const tl = gsap.timeline({ delay: 0.2 });
  tl.to('.hero-badge', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' })
    .to('.hero h1', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, '-=0.3')
    .to('.hero-sub', { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out' }, '-=0.5')
    .to('.hero-actions', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '-=0.4');

  gsap.to('.hero h1', {
    scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 1 },
    y: 80
  });
</script>
