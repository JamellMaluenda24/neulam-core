---

<style>
  .privacy {
    padding: 120px 60px;
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    position: relative;
    z-index: 1;
  }
  .privacy-inner { max-width: 860px; margin: 0 auto; }

  .privacy-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }
  .privacy-head .label {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
    display: block;
    margin-bottom: 10px;
  }
  .privacy-head h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 800;
    letter-spacing: -1.5px;
    line-height: 1.1;
  }
  .privacy-head-sub {
    color: var(--muted);
    font-size: 13px;
    line-height: 1.6;
    max-width: 220px;
    text-align: right;
  }

  /* LIST */
  .policy-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .policy-row {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 18px 0;
    border-bottom: 1px solid var(--border);
    opacity: 0;
    transform: translateX(-16px);
    transition: background 0.2s;
    cursor: default;
  }
  .policy-row:first-child { border-top: 1px solid var(--border); }
  .policy-row:hover .policy-title { color: var(--accent); }

  .policy-num {
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--accent);
    font-weight: 600;
    font-family: 'DM Sans', sans-serif;
    width: 28px;
    flex-shrink: 0;
  }
  .policy-title {
    font-family: 'Syne', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    transition: color 0.2s;
    flex: 1;
  }
  .policy-desc {
    font-size: 13px;
    color: var(--muted);
    flex: 1.2;
    line-height: 1.5;
  }
  .policy-arrow {
    color: var(--border);
    font-size: 14px;
    flex-shrink: 0;
    transition: color 0.2s, transform 0.2s;
  }
  .policy-row:hover .policy-arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  /* CTA */
  .privacy-cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 36px;
  }
  .privacy-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(0,212,200,0.07);
    border: 1px solid rgba(0,212,200,0.2);
    color: var(--accent);
    text-decoration: none;
    padding: 10px 20px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .privacy-cta-btn:hover {
    background: rgba(0,212,200,0.13);
    border-color: rgba(0,212,200,0.35);
    transform: translateY(-1px);
  }
  .privacy-cta-btn.secondary {
    background: rgba(255,255,255,0.03);
    border-color: var(--border);
    color: var(--muted);
  }
  .privacy-cta-btn.secondary:hover {
    border-color: rgba(255,255,255,0.15);
    color: var(--text);
  }

  @media (max-width: 900px) {
    .privacy { padding: 80px 24px; }
    .privacy-head { align-items: flex-start; }
    .privacy-head-sub { text-align: left; max-width: none; }
    .policy-desc { display: none; }
  }
  @media (max-width: 480px) {
    .privacy { padding: 60px 20px; }
    .privacy-head h2 { font-size: 26px; }
  }
</style>

<section class="privacy" id="privacy">
  <div class="privacy-inner">

    <div class="privacy-head">
      <div>
        <span class="label">Google Play Â· Cumplimiento</span>
        <h2>Privacidad &<br/>PolÃ­ticas</h2>
      </div>
      <p class="privacy-head-sub">7 Ã¡reas de polÃ­tica que cubre Ascend Habit Tracker.</p>
    </div>

    <div class="policy-list">
      {items.map(item => (
        <div class="policy-row">
          <span class="policy-num">{item.num}</span>
          <span class="policy-title">{item.title}</span>
          <span class="policy-desc">{item.desc}</span>
          <span class="policy-arrow">â†’</span>
        </div>
      ))}
    </div>

    <div class="privacy-cta">
      <a href="/privacy" class="privacy-cta-btn">Ver polÃ­tica detallada â†’</a>
      <a href="/permissions" class="privacy-cta-btn secondary">DeclaraciÃ³n de permisos â†’</a>
    </div>

  </div>
</section>

<script>
  gsap.utils.toArray('.policy-row').forEach((el, i) => {
    gsap.to(el, {
      scrollTrigger: { trigger: el, start: 'top 92%' },
      opacity: 1, x: 0,
      duration: 0.4,
      delay: i * 0.06,
      ease: 'power2.out',
    });
  });
</script>

