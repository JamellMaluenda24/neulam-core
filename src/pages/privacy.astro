---

<Layout title="Privacidad & PolÃ­ticas â€” Ascend Habit Tracker Â· Neulam Core">
<style>
  /* â”€â”€ HERO â”€â”€ */
  .lhero {
    padding: 140px 60px 60px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    position: relative; z-index: 1;
  }
  .lhero-inner { max-width: 960px; margin: 0 auto; }
  .lhero .label {
    font-size: 11px; letter-spacing: .15em; text-transform: uppercase;
    color: var(--accent); font-weight: 500; display: block; margin-bottom: 14px;
  }
  .lhero h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(32px,5vw,56px); font-weight: 800;
    letter-spacing: -2px; line-height: 1.05; margin-bottom: 20px;
  }
  .lhero-meta { color: var(--muted); font-size: 13px; display: flex; flex-wrap: wrap; align-items: center; gap: 12px; }
  .vbadge {
    background: rgba(0,212,200,.08); border: 1px solid rgba(0,212,200,.2);
    color: var(--accent); border-radius: 100px; padding: 4px 14px; font-size: 11px; font-weight: 500;
  }

  /* â”€â”€ BODY â”€â”€ */
  .lbody { position: relative; z-index: 1; background: var(--bg); }
  .linner { max-width: 960px; margin: 0 auto; padding: 64px 60px 100px; }

  /* â”€â”€ STEPPER RAIL â”€â”€ */
  .srail {
    display: flex; align-items: flex-start; gap: 0;
    position: relative; margin-bottom: 48px;
  }
  .srail::before {
    content: ''; position: absolute; top: 20px; left: 0; right: 0;
    height: 1px; background: var(--border); z-index: 0;
  }
  .srail::after {
    content: ''; position: absolute; top: 20px; left: 0;
    height: 1px; background: linear-gradient(to right, var(--accent), rgba(0,212,200,.4));
    z-index: 0; transition: width .4s ease; width: var(--progress,0%);
  }
  .sbtn {
    position: relative; z-index: 1; flex: 1;
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    cursor: pointer; background: none; border: none; padding: 0;
  }
  .sdot {
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--bg); border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 600; color: var(--muted);
    font-family: 'DM Sans', sans-serif; transition: all .25s ease;
  }
  .sbtn:hover .sdot { border-color: rgba(0,212,200,.4); color: var(--text); }
  .sbtn.active .sdot {
    background: var(--accent); border-color: var(--accent); color: var(--bg);
    box-shadow: 0 0 24px rgba(0,212,200,.45); font-weight: 700;
  }
  .sbtn.done .sdot { background: rgba(0,212,200,.1); border-color: rgba(0,212,200,.3); color: var(--accent); }
  .sshort {
    font-size: 10px; color: var(--muted); text-align: center; line-height: 1.3;
    max-width: 72px; transition: color .2s; font-family: 'DM Sans',sans-serif;
  }
  .sbtn.active .sshort { color: var(--accent); font-weight: 500; }

  /* â”€â”€ PANEL â”€â”€ */
  .spanel { position: relative; min-height: 200px; }
  .scard {
    position: absolute; inset: 0;
    opacity: 0; transform: translateY(10px);
    pointer-events: none; transition: opacity .3s ease, transform .3s ease;
  }
  .scard.active { opacity: 1; transform: translateY(0); pointer-events: all; position: relative; }

  /* â”€â”€ COMPACT CARD (steps 2-7) â”€â”€ */
  .compact-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 0;
    border: 1px solid var(--border); border-radius: 16px; overflow: hidden;
    transition: border-color .3s;
  }
  .compact-grid:hover { border-color: rgba(0,212,200,.15); }
  .cleft { padding: 36px; background: var(--surface); border-right: 1px solid var(--border); }
  .cright { padding: 36px; background: var(--surface2); }
  .cnum { font-size: 11px; letter-spacing: .15em; text-transform: uppercase; color: var(--accent); font-weight: 600; display: block; margin-bottom: 10px; font-family: 'DM Sans',sans-serif; }
  .ctitle { font-family: 'Syne',sans-serif; font-size: clamp(16px,2vw,20px); font-weight: 800; letter-spacing: -.5px; line-height: 1.2; margin-bottom: 6px; color: var(--text); }
  .clabel { font-size: 12px; color: var(--accent); opacity: .75; margin-bottom: 14px; }
  .csummary { font-size: 13px; color: var(--muted); line-height: 1.8; margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid var(--border); }
  .cidx-label { font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--muted); font-weight: 600; margin-bottom: 12px; display: block; font-family: 'DM Sans',sans-serif; }
  .cidx { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .cidx li { display: flex; align-items: flex-start; gap: 8px; font-size: 12px; color: var(--muted); line-height: 1.5; }
  .cidx li::before { content: 'â€”'; color: rgba(0,212,200,.4); font-size: 11px; flex-shrink: 0; }
  .clink { display: inline-flex; align-items: center; gap: 5px; margin-top: 20px; color: var(--accent); font-size: 12px; font-weight: 500; text-decoration: none; opacity: .8; transition: opacity .2s; }
  .clink:hover { opacity: 1; text-decoration: underline; }
  .cpts-label { font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--muted); font-weight: 600; margin-bottom: 16px; display: block; font-family: 'DM Sans',sans-serif; }
  .cpts { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 13px; }
  .cpts li { font-size: 13px; color: var(--muted); line-height: 1.7; padding-left: 14px; position: relative; }
  .cpts li::before { content: ''; position: absolute; left: 0; top: 8px; width: 4px; height: 4px; border-radius: 50%; background: var(--accent); opacity: .6; }
  .cpts li strong { color: var(--text); font-weight: 500; }

  /* â”€â”€ AUDIT REPORT (step 01) â”€â”€ */
  .audit-wrap {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }

  /* sidebar */
  .audit-sidebar {
    background: var(--surface);
    border-right: 1px solid var(--border);
    padding: 28px 0;
    position: sticky;
    top: 80px;
    height: fit-content;
    align-self: start;
  }
  .audit-sidebar-head {
    padding: 0 20px 16px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 12px;
  }
  .audit-sidebar-head .cnum { margin-bottom: 4px; }
  .audit-sidebar-head strong {
    font-family: 'Syne',sans-serif;
    font-size: 14px; font-weight: 700; color: var(--text); display: block;
  }
  .audit-sidebar-head span { font-size: 11px; color: var(--muted); }
  .audit-idx { list-style: none; padding: 0; margin: 0; }
  .audit-idx li a {
    display: flex; align-items: center; gap: 8px;
    padding: 7px 20px; font-size: 11px; color: var(--muted);
    text-decoration: none; transition: all .15s; line-height: 1.4;
  }
  .audit-idx li a:hover { background: rgba(0,212,200,.05); color: var(--text); }
  .audit-idx li a .idx-n { color: var(--accent); font-weight: 600; flex-shrink: 0; font-family: 'DM Sans',sans-serif; font-size: 10px; }

  /* content */
  .audit-content { background: var(--surface2); padding: 36px; }

  /* report header */
  .rpt-header {
    background: var(--bg); border: 1px solid var(--border);
    border-radius: 10px; padding: 20px 24px; margin-bottom: 40px;
    font-family: 'DM Mono','Courier New',monospace; font-size: 11px;
    color: var(--muted); line-height: 1.9;
  }
  .rpt-header .rpt-app { color: var(--accent); font-size: 13px; font-weight: 700; display: block; margin-bottom: 6px; }
  .rpt-header .rpt-title { color: var(--text); font-size: 12px; display: block; margin-bottom: 10px; }

  /* section */
  .rs { margin-bottom: 44px; scroll-margin-top: 100px; }
  .rs-head {
    display: flex; align-items: center; gap: 12px;
    border-bottom: 1px solid var(--border); padding-bottom: 12px; margin-bottom: 20px;
  }
  .rs-num {
    background: rgba(0,212,200,.08); border: 1px solid rgba(0,212,200,.2);
    color: var(--accent); border-radius: 4px; padding: 2px 8px;
    font-size: 10px; font-weight: 700; letter-spacing: .08em;
    font-family: 'DM Sans',sans-serif; white-space: nowrap;
  }
  .rs-title { font-family: 'Syne',sans-serif; font-size: 15px; font-weight: 700; color: var(--text); }

  /* sub-section */
  .rss { margin-bottom: 24px; }
  .rss-title { font-size: 12px; font-weight: 600; color: var(--accent); letter-spacing: .06em; text-transform: uppercase; margin-bottom: 10px; display: block; font-family: 'DM Sans',sans-serif; }

  /* para */
  .rp { font-size: 13px; color: var(--muted); line-height: 1.85; margin-bottom: 10px; }
  .rp:last-child { margin-bottom: 0; }
  .rp strong { color: var(--text); font-weight: 500; }
  .rp code, code { background: rgba(255,255,255,.06); border: 1px solid var(--border); border-radius: 4px; padding: 1px 6px; font-size: 11px; color: var(--accent); font-family: 'DM Mono','Courier New',monospace; }

  /* check/cross list */
  .cklist { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 7px; }
  .cklist li { display: flex; align-items: flex-start; gap: 8px; font-size: 13px; color: var(--muted); line-height: 1.65; }
  .ck-yes { color: var(--accent); font-weight: 700; flex-shrink: 0; }
  .ck-no  { color: #ff6b6b; font-weight: 700; flex-shrink: 0; }
  .ck-warn { color: #f5a623; font-weight: 700; flex-shrink: 0; }
  .ck-pend { color: #38bdf8; flex-shrink: 0; font-size: 12px; }

  /* table */
  .rtable { width: 100%; border-collapse: collapse; margin: 10px 0 16px; font-size: 12px; }
  .rtable th { background: var(--bg); color: var(--accent); padding: 8px 12px; text-align: left; font-size: 10px; letter-spacing: .1em; text-transform: uppercase; font-weight: 600; border-bottom: 1px solid var(--border); }
  .rtable td { padding: 8px 12px; border-bottom: 1px solid var(--border); vertical-align: top; color: var(--muted); line-height: 1.55; }
  .rtable td strong { color: var(--text); font-weight: 500; }
  .rtable tr:last-child td { border-bottom: none; }

  /* status badges */
  .ok   { display: inline-flex; align-items: center; gap: 4px; background: rgba(0,212,200,.08); border: 1px solid rgba(0,212,200,.2); color: var(--accent); border-radius: 4px; padding: 1px 7px; font-size: 10px; font-weight: 600; white-space: nowrap; }
  .warn { display: inline-flex; align-items: center; gap: 4px; background: rgba(245,166,35,.08); border: 1px solid rgba(245,166,35,.25); color: #f5a623; border-radius: 4px; padding: 1px 7px; font-size: 10px; font-weight: 600; white-space: nowrap; }
  .err  { display: inline-flex; align-items: center; gap: 4px; background: rgba(255,107,107,.08); border: 1px solid rgba(255,107,107,.25); color: #ff6b6b; border-radius: 4px; padding: 1px 7px; font-size: 10px; font-weight: 600; white-space: nowrap; }
  .info { display: inline-flex; align-items: center; gap: 4px; background: rgba(56,189,248,.08); border: 1px solid rgba(56,189,248,.25); color: #38bdf8; border-radius: 4px; padding: 1px 7px; font-size: 10px; font-weight: 600; white-space: nowrap; }

  /* note box */
  .rnote { background: rgba(245,166,35,.05); border-left: 3px solid #f5a623; border-radius: 0 6px 6px 0; padding: 12px 16px; margin: 14px 0; font-size: 12px; color: var(--muted); line-height: 1.7; }
  .rnote strong { color: var(--text); }

  /* veredicto */
  .veredicto { background: rgba(0,212,200,.06); border: 1px solid rgba(0,212,200,.2); border-radius: 12px; padding: 20px 24px; margin-top: 24px; }
  .veredicto-title { font-family: 'Syne',sans-serif; font-size: 16px; font-weight: 800; color: var(--accent); margin-bottom: 8px; }
  .veredicto p { font-size: 13px; color: var(--muted); line-height: 1.75; }
  .veredicto p strong { color: var(--text); }

  /* â”€â”€ NAV â”€â”€ */
  .snav { display: flex; align-items: center; justify-content: space-between; margin-top: 24px; }
  .snav-btn { background: none; border: 1px solid var(--border); color: var(--muted); border-radius: 100px; padding: 9px 20px; font-size: 13px; font-family: 'DM Sans',sans-serif; cursor: pointer; transition: all .2s; }
  .snav-btn:hover:not(:disabled) { border-color: rgba(0,212,200,.3); color: var(--text); }
  .snav-btn:disabled { opacity: .2; cursor: default; }
  .snav-count { font-size: 13px; color: var(--muted); font-family: 'DM Sans',sans-serif; }
  .snav-count strong { color: var(--accent); }

  /* â”€â”€ BOTTOM â”€â”€ */
  .see-also { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 56px; padding-top: 32px; border-top: 1px solid var(--border); }
  .see-also a { display: inline-flex; align-items: center; gap: 8px; background: rgba(0,212,200,.06); border: 1px solid rgba(0,212,200,.15); color: var(--accent); text-decoration: none; padding: 10px 20px; border-radius: 100px; font-size: 13px; font-weight: 500; transition: all .2s ease; }
  .see-also a:hover { background: rgba(0,212,200,.12); border-color: rgba(0,212,200,.3); transform: translateY(-1px); }
  .see-also a.m { background: rgba(255,255,255,.03); border-color: var(--border); color: var(--muted); }
  .see-also a.m:hover { border-color: rgba(255,255,255,.15); color: var(--text); }

  /* â”€â”€ RESPONSIVE â”€â”€ */
  @media (max-width: 900px) {
    .lhero { padding: 120px 24px 48px; }
    .linner { padding: 40px 24px 72px; }
    .compact-grid { grid-template-columns: 1fr; }
    .cleft { border-right: none; border-bottom: 1px solid var(--border); }
    .audit-wrap { grid-template-columns: 1fr; }
    .audit-sidebar { position: static; border-right: none; border-bottom: 1px solid var(--border); }
    .sshort { display: none; }
    .sdot { width: 34px; height: 34px; font-size: 10px; }
  }
  @media (max-width: 480px) {
    .lhero { padding: 100px 20px 36px; }
    .linner { padding: 32px 20px 60px; }
    .audit-content, .cleft, .cright { padding: 20px 16px; }
  }
</style>

