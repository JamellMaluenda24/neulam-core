                  <tr><td>Importancia</td><td>High</td><td>High</td></tr>
                </table>
              </div>

              <div class="rss">
                <span class="rss-title">6.3 Contenido de las notificaciones</span>
                <table class="rtable">
                  <tr><th>Tipo</th><th>Título</th><th>Cuerpo</th></tr>
