<script>
  const TOTAL = 7;
  let cur = 0;

  const btns  = Array.from(document.querySelectorAll('#sRail .sbtn'));
  const cards = Array.from(document.querySelectorAll('#sPanel .scard'));
  const rail  = document.getElementById('sRail');
  const prev  = document.getElementById('prevBtn');
  const next  = document.getElementById('nextBtn');
  const num   = document.getElementById('curNum');

  function go(i) {
    btns.forEach((b, idx) => {
      b.classList.toggle('active', idx === i);
      b.classList.toggle('done',   idx < i);
    });
    cards.forEach((c, idx) => c.classList.toggle('active', idx === i));
    rail.style.setProperty('--progress', TOTAL > 1 ? (i / (TOTAL - 1)) * 100 + '%' : '0%');
    num.textContent = i + 1;
    prev.disabled = i === 0;
    next.disabled = i === TOTAL - 1;
    cur = i;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  btns.forEach((b, i) => b.addEventListener('click', () => go(i)));
  prev.addEventListener('click', () => go(Math.max(0, cur - 1)));
  next.addEventListener('click', () => go(Math.min(TOTAL - 1, cur + 1)));
  go(0);
</script>

