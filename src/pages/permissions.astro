<style>
  .legal-hero {
    padding: 140px 60px 60px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    position: relative;
    z-index: 1;
  }
  .legal-hero-inner { max-width: 800px; margin: 0 auto; }
  .legal-hero .label {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
    display: block;
    margin-bottom: 14px;
  }
  .legal-hero h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800;
    letter-spacing: -2px;
    line-height: 1.05;
    margin-bottom: 20px;
  }
  .legal-hero-meta {
    color: var(--muted);
    font-size: 13px;
    letter-spacing: 0.04em;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
  }
  .version-badge {
    display: inline-flex;
    align-items: center;
    background: rgba(0,212,200,0.08);
    border: 1px solid rgba(0,212,200,0.2);
    color: var(--accent);
    border-radius: 100px;
    padding: 4px 14px;
    font-size: 11px;
    letter-spacing: 0.08em;
    font-weight: 500;
  }

  .legal-body {
    position: relative;
    z-index: 1;
    background: var(--bg);
  }
  .legal-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 56px 60px 100px;
  }

  /* INTRO BOX */
  .intro-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px 28px;
    margin-bottom: 48px;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.85;
  }
  .intro-box strong { color: var(--text); font-weight: 500; }

