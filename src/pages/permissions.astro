    flex-wrap: wrap;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  .see-also a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(0,212,200,0.06);
    border: 1px solid rgba(0,212,200,0.15);
    color: var(--accent);
    text-decoration: none;
    padding: 10px 20px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .see-also a:hover {
    background: rgba(0,212,200,0.12);
    border-color: rgba(0,212,200,0.3);
    transform: translateY(-1px);
  }
  .see-also a.secondary {
    background: rgba(255,255,255,0.03);
    border-color: var(--border);
    color: var(--muted);
  }
  .see-also a.secondary:hover {
    border-color: rgba(255,255,255,0.15);
    color: var(--text);
  }

  @media (max-width: 900px) {
    .legal-hero { padding: 120px 24px 48px; }
    .legal-inner { padding: 40px 24px 72px; }
  }
  @media (max-width: 480px) {
    .legal-hero { padding: 100px 20px 36px; }
    .legal-hero h1 { letter-spacing: -1px; }
    .legal-inner { padding: 32px 20px 60px; }
    .p-block { padding-left: 18px; }
    .p-block h2 { font-size: 17px; }
    .intro-box, .perm-card, .contact-box { padding: 16px 18px; }
  }
</style>

