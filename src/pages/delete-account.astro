---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Eliminar Cuenta | Ascend Habit Tracker"
  description="InformaciÃ³n sobre la eliminaciÃ³n de cuentas y datos asociados en Ascend Habit Tracker."
>
<style>
  .legal-hero {
    padding: 140px 60px 60px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    position: relative;
    z-index: 1;
  }
  .legal-hero-inner { max-width: 800px; margin: 0 auto; }
  .legal-hero .label {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
    display: block;
    margin-bottom: 14px;
  }
  .legal-hero h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800;
    letter-spacing: -2px;
    line-height: 1.05;
    margin-bottom: 20px;
  }
  .legal-hero-meta {
    color: var(--muted);
    font-size: 13px;
    letter-spacing: 0.04em;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
  }
  .version-badge {
    display: inline-flex;
    align-items: center;
    background: rgba(0,212,200,0.08);
    border: 1px solid rgba(0,212,200,0.2);
    color: var(--accent);
    border-radius: 100px;
    padding: 4px 14px;
    font-size: 11px;
    letter-spacing: 0.08em;
    font-weight: 500;
  }

  .legal-body {
    position: relative;
    z-index: 1;
    background: var(--bg);
  }
  .legal-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 56px 60px 100px;
  }

  /* INTRO BOX */
  .intro-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px 28px;
    margin-bottom: 48px;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.85;
  }
  .intro-box strong { color: var(--text); font-weight: 500; }

  /* BLOCKS */
  .p-block {
    border-left: 2px solid var(--border);
    padding-left: 28px;
    margin-bottom: 52px;
    scroll-margin-top: 100px;
    transition: border-color 0.3s ease;
  }
  .p-block:hover { border-color: rgba(0,212,200,0.35); }
  .p-block h2 {
    font-family: 'Syne', sans-serif;
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 20px;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .p-block h2 .section-icon {
    width: 28px; height: 28px;
    border-radius: 6px;
    background: rgba(0,212,200,0.1);
    border: 1px solid rgba(0,212,200,0.2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    flex-shrink: 0;
  }
  .p-block p {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.85;
    margin-bottom: 10px;
  }
  .p-block p:last-child { margin-bottom: 0; }
  .p-block p strong { color: var(--text); font-weight: 500; }

  /* STEPS LIST */
  .steps-list {
    list-style: none;
    padding: 0;
    margin: 10px 0 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .steps-list li {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    font-size: 14px;
    color: var(--muted);
    line-height: 1.7;
  }
  .step-num {
    width: 26px; height: 26px;
    border-radius: 50%;
    background: rgba(0,212,200,0.08);
    border: 1px solid rgba(0,212,200,0.25);
    color: var(--accent);
    font-size: 11px;
    font-weight: 700;
    font-family: 'DM Sans', sans-serif;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .steps-list li strong { color: var(--text); font-weight: 500; }

  /* CHECK LIST */
  .check-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .check-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--muted);
    line-height: 1.7;
  }
  .check-list li::before {
    content: 'âœ“';
    color: var(--accent);
    font-weight: 700;
    font-size: 13px;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .check-list li strong { color: var(--text); font-weight: 500; }

  /* INFO BOX */
  .info-box {
    background: rgba(0,212,200,0.05);
    border-left: 3px solid var(--accent);
    border-radius: 0 8px 8px 0;
    padding: 14px 18px;
    margin: 16px 0;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.7;
  }
  .info-box strong { color: var(--text); font-weight: 500; }

  /* CONTACT BOX */
  .contact-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px 28px;
    margin-top: 16px;
    transition: border-color 0.3s ease;
  }
  .contact-box:hover { border-color: rgba(0,212,200,0.2); }
  .contact-box p { color: var(--muted); font-size: 14px; line-height: 1.8; margin-bottom: 6px; }
  .contact-box p:last-child { margin-bottom: 0; }
  .contact-box strong { color: var(--text); font-weight: 600; }
  .contact-box a { color: var(--accent); text-decoration: none; }
  .contact-box a:hover { text-decoration: underline; }

  /* SEE ALSO */
  .see-also {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  .see-also a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(0,212,200,0.06);
    border: 1px solid rgba(0,212,200,0.15);
    color: var(--accent);
    text-decoration: none;
    padding: 10px 20px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .see-also a:hover {
    background: rgba(0,212,200,0.12);
    border-color: rgba(0,212,200,0.3);
    transform: translateY(-1px);
  }
  .see-also a.secondary {
    background: rgba(255,255,255,0.03);
    border-color: var(--border);
    color: var(--muted);
  }
  .see-also a.secondary:hover {
    border-color: rgba(255,255,255,0.15);
    color: var(--text);
  }

  @media (max-width: 900px) {
    .legal-hero { padding: 120px 24px 48px; }
    .legal-inner { padding: 40px 24px 72px; }
  }
  @media (max-width: 480px) {
    .legal-hero { padding: 100px 20px 36px; }
    .legal-hero h1 { letter-spacing: -1px; }
    .legal-inner { padding: 32px 20px 60px; }
    .p-block { padding-left: 18px; }
    .p-block h2 { font-size: 17px; }
    .intro-box, .contact-box { padding: 16px 18px; }
  }
</style>

